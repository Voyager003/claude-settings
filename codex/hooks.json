{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.codex/hooks/session-start-context.sh",
            "timeout": 10,
            "statusMessage": "Loading git context"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.codex/hooks/guardrail.py",
            "timeout": 10,
            "statusMessage": "Checking Bash command"
          },
          {
            "type": "command",
            "command": "python3 ~/.codex/hooks/pre-bash-block-no-verify.py",
            "timeout": 5,
            "statusMessage": "Blocking hook bypass flags"
          },
          {
            "type": "command",
            "command": "python3 ~/.codex/hooks/pre-bash-commit-quality.py",
            "timeout": 30,
            "statusMessage": "Pre-commit quality check"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.codex/hooks/user-prompt-inject.py",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.codex/hooks/stop-self-check.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
